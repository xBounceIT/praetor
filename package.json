{
  "name": "praetor",
  "private": true,
  "version": "0.12.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "bun run docs:user && vite build && bun scripts/verify-production-build.mjs dist",
    "preview": "vite preview",
    "i18n:check": "bun scripts/check-i18n-keys.mjs",
    "typecheck": "tsc -p server/tsconfig.json && tsc -p tsconfig.json",
    "test": "bun run test:server && bun run test:frontend",
    "test:server": "cd server && bun test ./test",
    "test:frontend": "bun test ./test",
    "test:react-doctor": "bun x -y react-doctor@latest .",
    "test:coverage": "bun run test:server -- --coverage && bun run test:frontend -- --coverage",
    "lint": "bun run i18n:check && bun run typecheck && biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "docs:frontend": "typedoc --options typedoc.json",
    "docs:api": "cd server && bun ./scripts/generate-openapi.ts",
    "docs:user": "astro build --root docs-site",
    "docs:user:dev": "astro dev --root docs-site",
    "docs": "bun run docs:frontend && bun run docs:api && bun run docs:user",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@tanstack/react-table": "^8.21.3",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "exceljs": "^4.4.0",
    "flag-icons": "^7.5.0",
    "html-to-image": "^1.11.13",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "input-otp": "^1.4.2",
    "ldapjs": "^3.0.7",
    "lucide-react": "^1.16.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-hook-form": "^7.76.1",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "simple-icons": "^16.19.0",
    "sonner": "^2.0.7",
    "swagger-ui-react": "^5.32.5",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/starlight": "^0.39.2",
    "@biomejs/biome": "^2.4.14",
    "@happy-dom/global-registrator": "^20.9.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.14",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ldapjs": "^3.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "astro": "^7.1.3",
    "autoprefixer": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.13",
    "sirv": "^3.0.2",
    "tailwindcss": "^4.2.4",
    "tw-animate-css": "^1.4.0",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
