{
  "name": "praetor",
  "private": true,
  "version": "0.5.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "i18n:check": "bun scripts/check-i18n-keys.mjs",
    "typecheck": "tsc -p server/tsconfig.json && tsc -p tsconfig.json",
    "test": "bun test server/test test",
    "test:coverage": "bun test server/test test --coverage",
    "lint": "bun run i18n:check && bun run typecheck && biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "docs:frontend": "typedoc --options typedoc.json",
    "docs:api": "bun ./server/scripts/generate-openapi.ts",
    "docs": "bun run docs:frontend; bun run docs:api",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "flag-icons": "^7.5.0",
    "i18next": "^26.0.8",
    "i18next-browser-languagedetector": "^8.2.1",
    "inquirer": "^13.4.2",
    "ldapjs": "^3.0.7",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-i18next": "^17.0.6",
    "react-markdown": "^10.1.0",
    "recharts": "^3.8.1",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "swagger-ui-react": "^5.32.5"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@biomejs/cli-win32-x64": "^2.4.14",
    "@happy-dom/global-registrator": "^20.9.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@tailwindcss/vite": "^4.2.4",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.3.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ldapjs": "^3.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "autoprefixer": "^10.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "postcss": "^8.5.13",
    "sirv": "^3.0.2",
    "tailwindcss": "^4.2.4",
    "typedoc": "^0.28.19",
    "typescript": "^6.0.3",
    "vite": "^8.0.10"
  }
}
