{
  "name": "praetor-server",
  "version": "0.5.0",
  "description": "Praetor API Server",
  "main": "dist/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "bun run dist/index.js",
    "dev": "bun --watch index.ts",
    "seed:demo": "bun run scripts/seed-demo.ts",
    "db:generate": "drizzle-kit generate",
    "db:generate:custom": "drizzle-kit generate --custom",
    "db:migrate": "bun run scripts/run-migrations.ts",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-rate-limit": "npm:@fastify/rate-limit@^10.3.0",
    "jsonwebtoken": "^9.0.3",
    "ldapjs": "^3.0.7",
    "nodemailer": "^8.0.7",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "selfsigned": "^5.5.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/ldapjs": "^3.0.6",
    "@types/node": "^25.6.0",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^6.0.3"
  }
}
