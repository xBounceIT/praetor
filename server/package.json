{
  "name": "praetor-server",
  "version": "0.5.0",
  "description": "Praetor API Server",
  "main": "dist/index.ts",
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "bun run dist/index.js",
    "dev": "bun --watch index.ts",
    "seed:demo": "bun run scripts/seed-demo.ts",
    "db:generate": "drizzle-kit generate",
    "db:generate:custom": "drizzle-kit generate --custom",
    "db:migrate": "drizzle-kit migrate",
    "db:check": "drizzle-kit check",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@fastify/cors": "^10.1.0",
    "@fastify/swagger": "^9.7.0",
    "bcryptjs": "^2.4.3",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.8.5",
    "fastify-rate-limit": "npm:@fastify/rate-limit@^10.3.0",
    "jsonwebtoken": "^9.0.2",
    "ldapjs": "^3.0.7",
    "nodemailer": "^8.0.5",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.2",
    "selfsigned": "^2.4.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/ldapjs": "^2.2.5",
    "@types/node": "^22.19.17",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "typescript": "^5.9.3"
  }
}
