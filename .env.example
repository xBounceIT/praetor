# Docker Compose Configuration (Developer compose)
# These variables are used by docker-compose.yml to configure local source builds.
# Replace with your server's public IP or domain name
SERVER_IP=localhost

# Database Credentials
POSTGRES_USER=praetor
POSTGRES_PASSWORD=praetor
POSTGRES_DB=praetor

# Redis (optional, used as cache by backend)
# If unset, docker-compose.yml defaults to redis://redis:6379/0
# REDIS_URL=redis://redis:6379/0

# Application Secrets
JWT_SECRET=praetor-secret-key-change-in-production
ENCRYPTION_KEY=praetor-encryption-key-change-in-production

# Logging (backend)
# LOG_LEVEL supports: trace, debug, info, warn, error, fatal
LOG_LEVEL=info
# Pretty logs are enabled by default outside production; set explicitly if needed.
# LOG_PRETTY=true

# Optional demo data seeding on backend startup
DEMO_SEEDING=false

# Default password for bootstrap admin user (username: admin)
# Used only when the admin user does not already exist.
ADMIN_DEFAULT_PASSWORD=password
